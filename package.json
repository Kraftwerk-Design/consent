{
  "name": "@kraftwerk/consent",
  "version": "0.1.0",
  "description": "Cookie consent built on vanilla-cookieconsent with GPC support, analytics gating, and consent-gated embeds.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "vanilla-cookieconsent": "^3.0.0"
  },
  "devDependencies": {
    "tsdown": "latest",
    "typescript": "^5.5.0",
    "vanilla-cookieconsent": "^3.1.0"
  },
  "license": "UNLICENSED",
  "private": false
}
